APP_NAME="Every Bite"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# SPA base URL (password-reset links point here)
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Use 'errorlog' in production (streams to Railway/hosting log viewer; no file writes)
LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- DATABASE ---
# Dev: sqlite  |  Production: pgsql
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=every_bite
# DB_USERNAME=every_bite
# DB_PASSWORD=

# --- SESSION / CACHE / QUEUE ---
# Stateless token API — use 'array' in production (no DB/file sessions needed)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# --- CORS ---
# Comma-separated allowed origins.
# Capacitor Android WebView (androidScheme=https) sends Origin: https://localhost
CORS_ALLOWED_ORIGINS=https://localhost

# --- SANCTUM ---
# Minutes until an API token expires (43200 = 30 days; null = never)
SANCTUM_TOKEN_EXPIRATION=43200

# --- MAIL ---
# Use 'log' in dev/staging; configure smtp (Resend/Mailgun/SES) for real email in prod
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@everybite.app"
MAIL_FROM_NAME="${APP_NAME}"
